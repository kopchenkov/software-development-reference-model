        <child xsi:type="archimate:Note" id="id-b6e0474b4c7441a78f779f3a229c1b54" textAlignment="1">
          <bounds x="60" y="108" width="985" height="49"/>
          <content>SOFTWARE DEVELOPMENT REFERENCE MODEL
