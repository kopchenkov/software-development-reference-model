            <child xsi:type="archimate:DiagramObject" id="id-bc6b8e00fe1e4558afa22faa61c5c573" targetConnections="id-985cf165969b445dbb039eb9e86752b0" textPosition="1" archimateElement="id-365eeb87ebc54553b87bb9ffdb59509b">
