            <child xsi:type="archimate:DiagramObject" id="id-87912acdbe304cc8a131521b27ff4a4b" targetConnections="id-9635c542a38647628f2138c7f97870db" textPosition="1" archimateElement="id-e22590454b3543c8b13a655b3ded3693">
              <bounds x="24" y="264" width="120" height="85"/>
            </child>
            <child xsi:type="archimate:DiagramObject" id="id-066def6805a540f48cfaa5e7786aba20" targetConnections="id-fd07f7bf5ec94065aa66851b4f7b2ee8" textPosition="1" archimateElement="id-806398ab2adc4b46baa2dc73b5f04399">
              <bounds x="24" y="132" width="120" height="55"/>
            </child>
            <child xsi:type="archimate:DiagramObject" id="id-43dd7d10a8fe40218765e670eeb99252" targetConnections="id-4200a550a79949fba31596f0cea94552" textPosition="1" archimateElement="id-82cc3e78ae604158be5ce95ef84b4e58">
