            <child xsi:type="archimate:DiagramObject" id="id-0f7d5d777a68498bbdd26c6b66e27734" targetConnections="id-d5832d91007841fbaae03c67dbf9e2c7" textPosition="1" archimateElement="id-e8c9951bcb474e92a59d90e4786e3e0b">
